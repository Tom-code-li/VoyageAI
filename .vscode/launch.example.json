{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Run VoyageAI Backend (.env)",
      "request": "launch",
      "mainClass": "com.example.travelassistant.TravelAssistantApplication",
      "projectName": "travel-assistant",
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "type": "java",
      "name": "Run VoyageAI Backend (direct env)",
      "request": "launch",
      "mainClass": "com.example.travelassistant.TravelAssistantApplication",
      "projectName": "travel-assistant",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "SERVER_PORT": "8080",
        "DB_HOST": "localhost",
        "DB_PORT": "3306",
        "DB_NAME": "travel_assistant",
        "DB_USERNAME": "root",
        "DB_PASSWORD": "your-db-password",
        "AI_ENABLED": "true",
        "AI_BASE_URL": "https://api.deepseek.com",
        "AI_API_KEY": "your-ai-api-key",
        "AI_MODEL": "deepseek-chat",
        "AMAP_WEB_SERVICE_KEY": "your-amap-web-service-key"
      }
    }
  ]
}
